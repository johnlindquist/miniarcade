  "categories": {
    "characterCraft": {
      "meetsMachineHunt": true,
      "meetsBlockMine": true,
      "note": "At native 160x360, the persistent forge operator has a built helmet, apron, face, boots, crank/brace/hurt/cheer poses, and readable movement between the three launch banks. The white-hot workpiece, falling slag body, and gear/valve/turbine/heart casts remain distinct small silhouettes rather than placeholder dots."
    },
    "environmentCraft": {
      "meetsMachineHunt": true,
      "meetsBlockMine": true,
      "note": "The fixed board is an authored industrial room: furnace, stamp, quench tank, die, director anvil, pressure valve, return cup, three launch ports, destructible blueprint clutter, rear engine, skyline, rails, fasteners, heat bars, and order panel all use layered material detail comparable to the references."
    },
    "levelVariety": {
      "meetsMachineHunt": true,
      "meetsBlockMine": true,
      "note": "The montage shows more than palette swaps: process impacts occupy different machines, warned slag reserves a lane, counterplay moves the operator to the valve, wrong order warps the workpiece, cast parts physically accumulate in the rear engine, and the heart changes the completed composition."
    },
    "animationImpact": {
      "meetsMachineHunt": true,
      "meetsBlockMine": true,
      "note": "Executable burst receipts prove moving charge ignition, orbiting machine sparks, warning pulses, cast rotation, installed engine motion, and heart-apex motion. The native frames also show anticipation and follow-through through the operator crank/brace/cheer poses, lane warning, impact flashes, cast lift, and persistent installation."
    },
    "readability": {
      "meetsMachineHunt": true,
      "meetsBlockMine": true,
      "note": "The current order, next process, heat bar, pressure, selected bank, tactic caption, warned lane, counter location, good/bad full-board grammar, installed parts, and final online state read at native size. Planner contamination is an exact pixel no-op, so no hidden forecast is laundered into a route overlay."
    },
    "artDirectionCohesion": {
      "meetsMachineHunt": true,
      "meetsBlockMine": true,
      "note": "Copper, iron, ember orange, quench cyan, hazard red, cream highlights, beveled machine silhouettes, compact pixel type, and the shared pulse/particle grammar form one coherent foundry. The subject footprint stays below eight percent while the environment remains richly authored."
    }
