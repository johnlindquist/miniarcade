{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "arcade-foundry-design-claim/v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema", "id", "game", "evaluationEpoch", "inputManifestSha256", "predicate", "statement", "support", "validationTarget", "payloadSha256"],
  "properties": {
    "schema": {"const": "arcade-foundry-design-claim/v1"},
    "id": {"type": "string", "minLength": 1},
    "game": {"const": "tower-panic"},
    "evaluationEpoch": {"type": "string", "minLength": 1},
    "inputManifestSha256": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
    "predicate": {
      "type": "object",
      "additionalProperties": false,
      "required": ["field", "operator", "value"],
      "properties": {
        "field": {"const": "threatLeadFrames"},
        "operator": {"const": "equals"},
        "value": {"const": 36}
      }
    },
    "statement": {"type": "string", "minLength": 1},
    "support": {"type": "array", "minItems": 1},
    "validationTarget": {"type": "object", "required": ["threatLeadFrames"]},
    "payloadSha256": {"type": "string", "pattern": "^[a-f0-9]{64}$"}
  }
}
